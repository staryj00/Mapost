<?xml version="1.0" encoding="UTF-8"?>

    <LinearLayout android:weightSum="1" android:orientation="vertical" tools:context=".FindMemActivity" android:layout_height="match_parent" android:layout_width="match_parent" xmlns:tools="http://schemas.android.com/tools" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:android="http://schemas.android.com/apk/res/android">


    <LinearLayout android:orientation="horizontal" android:layout_height="0dp" android:layout_width="match_parent" android:layout_weight="0.15">

    <EditText android:layout_height="wrap_content" android:layout_width="wrap_content" android:layout_weight="1" android:fontFamily="@font/dovemayo" android:layout_marginBottom="20dp" android:layout_marginTop="20dp" android:padding="10dp" android:inputType="textPersonName" android:hint="회원 닉네임 검색" android:ems="10" android:id="@+id/etxtMem"/>

    <Button android:layout_height="40dp" android:layout_width="40dp" android:layout_weight="1" android:fontFamily="@font/dovemayo" android:layout_marginTop="20dp" android:id="@+id/btnSearch" android:textColor="#ffffff" android:layout_marginRight="5dp" android:background="@drawable/btncorner" android:text="SEARCH"/>

</LinearLayout>


    <LinearLayout android:orientation="vertical" android:layout_height="0dp" android:layout_width="match_parent" android:layout_weight="0.68">

    <TextView android:layout_height="wrap_content" android:layout_width="match_parent" android:fontFamily="@font/nanumgothicextrabold" android:layout_marginTop="50dp" android:id="@+id/txtvFriend" android:textSize="25sp" android:gravity="center"/>


    <LinearLayout android:layout_height="wrap_content" android:layout_width="wrap_content" android:layout_marginTop="30dp" android:layout_gravity="center">

        <ImageView
            android:id="@+id/imgv"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:visibility="invisible"
            android:background="@drawable/icon_profile" />

</LinearLayout>

        <android.support.v7.widget.RecyclerView
            android:id="@+id/recyclerviewMemos"
            android:layout_width="match_parent"
            android:layout_height="350dp"
            android:textFilterEnabled="true">

        </android.support.v7.widget.RecyclerView>

</LinearLayout>


    <LinearLayout android:layout_height="0dp" android:layout_width="match_parent" android:layout_weight="0.17">

    <com.airbnb.lottie.LottieAnimationView android:layout_height="match_parent" android:layout_width="wrap_content" android:id="@+id/animation_view_banner" app:lottie_loop="true" app:lottie_fileName="banner_animation.json" app:lottie_autoPlay="true" android:scaleType="centerCrop"/>

</LinearLayout>

</LinearLayout>