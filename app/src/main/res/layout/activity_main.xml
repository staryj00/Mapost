<?xml version="1.0" encoding="UTF-8"?>

    <LinearLayout android:background="#ffffff" tools:context=".MainActivity" android:orientation="vertical" android:layout_height="match_parent" android:layout_width="match_parent" xmlns:tools="http://schemas.android.com/tools" xmlns:app="http://schemas.android.com/apk/res-auto" xmlns:android="http://schemas.android.com/apk/res/android">

    <ImageView android:layout_height="wrap_content" android:layout_width="match_parent" android:layout_marginTop="20dp" app:srcCompat="@drawable/logo" android:id="@+id/imageView2"/>


    <LinearLayout android:background="#ffffff" android:orientation="horizontal" android:layout_height="wrap_content" android:layout_width="match_parent" android:layout_marginTop="50dp" android:weightSum="1">

    <TextView android:layout_height="wrap_content" android:layout_width="0dp" android:id="@+id/textView8" android:textColor="#000000" android:layout_weight="0.4" android:textSize="20dp" android:text="ID :" android:gravity="right"/>

    <android.support.design.widget.TextInputEditText android:background="@drawable/my_border" android:layout_height="wrap_content" android:layout_width="0dp" android:id="@+id/etxtid" android:layout_weight="0.5" android:textSize="20dp" android:textCursorDrawable="@drawable/cursor_color" android:padding="10dp" android:inputType="textPersonName" android:ems="10" android:layout_marginLeft="30dp"/>

</LinearLayout>


    <LinearLayout android:background="#ffffff" android:orientation="horizontal" android:layout_height="wrap_content" android:layout_width="match_parent" android:layout_marginTop="30dp" android:weightSum="1">

    <TextView android:layout_height="wrap_content" android:layout_width="0dp" android:id="@+id/textView9" android:textColor="#000000" android:layout_weight="0.4" android:textSize="20dp" android:text="PASSWORD :" android:gravity="right"/>

    <android.support.design.widget.TextInputEditText android:background="@drawable/my_border" android:layout_height="wrap_content" android:layout_width="0dp" android:id="@+id/etxtpwd" android:layout_weight="0.5" android:textSize="20dp" android:textCursorDrawable="@drawable/cursor_color" android:padding="10dp" android:inputType="textPassword" android:ems="10" android:layout_marginLeft="30dp"/>

</LinearLayout>


    <LinearLayout android:background="#ffffff" android:orientation="horizontal" android:layout_height="match_parent" android:layout_width="match_parent" android:layout_marginTop="30dp">

    <Button android:background="@drawable/btncorner" android:layout_height="wrap_content" android:layout_width="wrap_content" android:id="@+id/btnLogin" android:textColor="#ffffff" android:layout_weight="1" android:textSize="20sp" android:text="로그인" android:textStyle="bold" android:layout_margin="30dp"/>

    <Button android:background="@drawable/btncorner" android:layout_height="wrap_content" android:layout_width="wrap_content" android:id="@+id/btnReg" android:textColor="#ffffff" android:layout_weight="1" android:textSize="20sp" android:text="회원가입" android:textStyle="bold" android:layout_margin="30dp"/>

</LinearLayout>

</LinearLayout>