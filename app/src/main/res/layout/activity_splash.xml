<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".SplashActivity"
    android:background="#ffffff">

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <com.airbnb.lottie.LottieAnimationView android:layout_height="wrap_content" android:layout_width="wrap_content" app:lottie_loop="true" app:lottie_fileName="planet_rotating.json" app:lottie_autoPlay="true" android:layout_margin="20dp" android:layout_gravity="center" android:id="@+id/animation_view"/>

        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:id="@+id/animation_text" android:typeface="sans" android:textStyle="bold" android:textSize="80dp" android:textColor="#000000" android:text="MaPost." android:gravity="center" android:layout_alignTop="@id/animation_view" android:layout_alignRight="@id/animation_view" android:layout_alignLeft="@id/animation_view" android:layout_alignBottom="@id/animation_view"/>

        <TextView android:layout_height="wrap_content" android:layout_width="wrap_content" android:id="@+id/animation_text2" android:typeface="sans" android:textStyle="bold" android:textSize="70dp" android:textColor="#000000" android:text="GO!" android:gravity="bottom|center" android:layout_alignTop="@id/animation_view" android:layout_alignRight="@id/animation_view" android:layout_alignLeft="@id/animation_view" android:layout_alignBottom="@id/animation_view"/>


    </RelativeLayout>


</LinearLayout>